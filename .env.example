# Copy this to .env and fill in your values

# Flask session security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string

# Admin PIN (6 digits recommended, different from all user PINs)
ADMIN_PIN=0000

# football-data.org API key — free registration at https://www.football-data.org/client/register
# Without this, auto-sync is disabled (you can still enter results manually in the admin panel).
FDORG_API_KEY=

# Leave blank to use the default SQLite file (wkpoule.db)
# DATABASE_URL=sqlite:///wkpoule.db
